# =====================================================================
# Frontend (Vite) — copy this file to .env.local and fill in.
# =====================================================================
# Run `npx convex dev` once to get your deployment URL.
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# =====================================================================
# Backend (Convex) — DO NOT put these in .env.local.
# Set them on the Convex deployment instead:
#   npx convex env set <NAME> <VALUE>
#   npx convex env list
# =====================================================================

# REQUIRED for the AI triage agent (chat completions + tool calling):
#   npx convex env set OPENROUTER_API_KEY sk-or-...
# Optional, defaults to openai/gpt-4o-mini:
#   npx convex env set OPENROUTER_MODEL openai/gpt-4o-mini

# REQUIRED for RAG / similar-issue retrieval (embeddings):
#   npx convex env set OPENAI_API_KEY sk-...
# Without this, the agent still runs but skips the search_similar_issues
# tool — you lose the duplicate-detection and assignee-suggestion signal.

# Optional Google OAuth (only needed if you enable sign-in):
#   npx convex env set AUTH_GOOGLE_ID <client-id>.apps.googleusercontent.com
#   npx convex env set AUTH_GOOGLE_SECRET <client-secret>
#   npx convex env set SITE_URL http://localhost:5173

# Required when deploying a protected instance:
#   npx convex env set ALLOWED_EMAILS "you@example.com,teammate@example.com"
