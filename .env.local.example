# Copy this file to .env.local and fill in your Convex deployment URL
# Run `npx convex dev` to get your deployment URL
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# OpenRouter (Convex backend only — set on the deployment, not in Vite):
#   npx convex env set OPENROUTER_API_KEY sk-or-...
#   npx convex env set OPENROUTER_MODEL openai/gpt-4o-mini
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
